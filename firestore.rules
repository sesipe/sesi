rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && getUserData().role == 'school_admin' && getUserData().schoolId == schoolId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidSchool(data) {
      return data.keys().hasAll(['name', 'city', 'email', 'code', 'status'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.city is string && data.city.size() > 0 && data.city.size() <= 100
        && data.email is string && data.email.size() <= 256
        && data.code is string && data.code.size() <= 20
        && data.status in ['active', 'inactive'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['responsibleName', 'relationship', 'email', 'whatsapp', 'schoolId', 'schoolName', 'course', 'series', 'status', 'createdAt'])
        && data.keys().size() >= 10
        && data.responsibleName is string && data.responsibleName.size() <= 200
        && data.relationship is string && data.relationship.size() <= 50
        && data.email is string && data.email.size() <= 256
        && data.whatsapp is string && data.whatsapp.size() <= 20
        && data.schoolId is string && isValidId(data.schoolId)
        && data.course is string && data.course.size() <= 100
        && data.series is string && data.series.size() <= 100
        && data.status in ['Novo', 'Contatado', 'Matriculado', 'Desistente']
        && data.createdAt == request.time;
    }

    // --- Collections ---

    // Schools
    match /schools/{schoolId} {
      allow read: if true; // Public needs to see schools for the form
      allow create, update: if isAdmin() && isValidSchool(incoming());
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Leads
    match /leads/{leadId} {
      // Creation is public for the landing page
      allow create: if isValidLead(incoming()) && incoming().status == 'Novo';
      
      // Admin can see everything
      // School Admin can see leads for their school
      allow get: if isAdmin() || isSchoolAdmin(existing().schoolId);
      allow list: if isAdmin() || (isSignedIn() && getUserData().role == 'school_admin' && resource.data.schoolId == getUserData().schoolId);

      allow update: if (isAdmin() || isSchoolAdmin(existing().schoolId)) && (
        // Validation helper call is MANDATORY for updates
        // Note: simplified isValidLead check or specific field checks
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'observations', 'updatedAt']) 
         && incoming().updatedAt == request.time
         && incoming().status in ['Novo', 'Contatado', 'Matriculado', 'Desistente'])
      );

      allow delete: if isAdmin();

      // Lead History
      match /history/{historyId} {
        allow read: if isAdmin() || isSchoolAdmin(get(/databases/$(database)/documents/leads/$(leadId)).data.schoolId);
        allow create: if (isAdmin() || isSchoolAdmin(get(/databases/$(database)/documents/leads/$(leadId)).data.schoolId))
          && incoming().leadId == leadId
          && incoming().timestamp == request.time;
      }
    }

    // Logs
    match /logs/{logId} {
      allow read, create: if isAdmin();
    }
  }
}
